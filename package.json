{
  "name": "apostil",
  "version": "0.1.4",
  "description": "Lightweight, Figma-like commenting for React & Next.js — pin comments directly on your UI",
  "license": "MIT",
  "author": "Batzorigco",
  "repository": {
    "type": "git",
    "url": "https://github.com/batzorigco/apostil.git"
  },
  "keywords": [
    "comments",
    "commenting",
    "inline-comments",
    "figma-like",
    "feedback",
    "annotation",
    "react",
    "nextjs",
    "overlay",
    "review",
    "collaboration",
    "pin-comments",
    "lightweight"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/localStorage": {
      "types": "./dist/adapters/localStorage.d.ts",
      "import": "./dist/adapters/localStorage.js",
      "require": "./dist/adapters/localStorage.cjs"
    },
    "./adapters/rest": {
      "types": "./dist/adapters/rest.d.ts",
      "import": "./dist/adapters/rest.js",
      "require": "./dist/adapters/rest.cjs"
    },
    "./adapters/nextjs": {
      "types": "./dist/adapters/nextjs.d.ts",
      "import": "./dist/adapters/nextjs.js",
      "require": "./dist/adapters/nextjs.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "bin": {
    "apostil": "./bin/apostil.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && npx @tailwindcss/cli -i src/styles/apostil.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^29.0.1",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.2.2",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
